# Telegram
TELEGRAM_BOT_TOKEN=

# MongoDB persistence
MONGODB_URI=

# Wallet encryption. Use a long random secret. Required for create/import wallet mode.
ENCRYPTION_KEY=

# Chain configuration
CHAIN_RPC_URL=
CHAIN_ID=1
NATIVE_SYMBOL=ETH

# Optional integrations. Bot still boots without these, but live quotes/trading/PnL may be partial.
DEX_AGGREGATOR_API_URL=
BLOCK_EXPLORER_URL=
PRICE_API_URL=

# Optional runtime controls
SNIPE_POLL_MS=15000
